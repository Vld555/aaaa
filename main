from sklearn.model_selection import cross_val_predict
from sklearn.metrics import classification_report, confusion_matrix, roc_auc_score

print("\n--- ЧАСТЬ 8: Сдвиг порога с кросс-валидацией (Out-of-Fold) ---")

# 1. Задаем порог, который хотим проверить (например, 15% уверенности)
# Попробуйте поменять на 0.10 или 0.05, если Recall будет недостаточным.
CUSTOM_THRESHOLD = 0.15 
print(f"Вычисляем метрики CV для порога: {CUSTOM_THRESHOLD * 100}%...\n")

# 2. Получаем вероятности для ВСЕГО датасета честным путем через кросс-валидацию.
# Используем наш стандартный пайплайн (без scale_pos_weight)
y_proba_cv = cross_val_predict(
    pipeline_xgb, 
    X, y, 
    cv=cv_strategy, 
    method='predict_proba', 
    n_jobs=-1
)[:, 1]

# 3. Применяем наш порог: если вероятность >= порога, ставим 1 (Атака)
y_pred_cv_custom = (y_proba_cv >= CUSTOM_THRESHOLD).astype(int)

# 4. Оцениваем результат сравнением истинных y и предсказанных
print("Матрица ошибок (на всех фолдах суммарно):")
print(confusion_matrix(y, y_pred_cv_custom))

print("\nОтчет о классификации (Classification Report):")
print(classification_report(y, y_pred_cv_custom, digits=4))

# ROC-AUC не зависит от сдвига порога, он оценивает сами вероятности
roc_auc_cv = roc_auc_score(y, y_proba_cv)
print(f"ROC-AUC (OOF): {roc_auc_cv:.4f}")
