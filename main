import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.feature_extraction.text import CountVectorizer

# Настройки для графиков
sns.set_theme(style="whitegrid")

def simple_text_eda(df, text_col='text', label_col='label'):
    """
    Простой скрипт для разведочного анализа текста (бинарная классификация).
    df: pandas DataFrame
    text_col: название колонки с текстом
    label_col: название колонки с таргетом (0 или 1)
    """
    
    print("=== 1. Базовая статистика и баланс классов ===")
    print(f"Всего записей: {len(df)}")
    print(f"Пустых значений в текстах: {df[text_col].isnull().sum()}")
    print(f"Полных дубликатов строк: {df.duplicated().sum()}")
    
    # Распределение классов
    class_counts = df[label_col].value_counts()
    print("\nБаланс классов:")
    print(class_counts.to_string())
    
    plt.figure(figsize=(6, 4))
    sns.barplot(x=class_counts.index, y=class_counts.values, palette='viridis')
    plt.title('Распределение классов')
    plt.xlabel('Класс (Label)')
    plt.ylabel('Количество')
    plt.show()

    print("\n=== 2. Анализ длины текстов ===")
    # Считаем количество слов (по пробелам) и символов
    df['word_count'] = df[text_col].astype(str).apply(lambda x: len(x.split()))
    df['char_count'] = df[text_col].astype(str).apply(len)
    
    print("Статистика по количеству слов:")
    print(df.groupby(label_col)['word_count'].describe()[['mean', 'min', 'max']])
    
    # График распределения длины слов по классам
    plt.figure(figsize=(10, 5))
    sns.histplot(data=df, x='word_count', hue=label_col, kde=True, bins=50, palette='viridis')
    plt.title('Распределение количества слов в зависимости от класса')
    plt.xlabel('Количество слов')
    plt.ylabel('Плотность')
    # Ограничим X, чтобы выбросы (очень длинные тексты) не сплющили график
    plt.xlim(0, df['word_count'].quantile(0.95)) 
    plt.show()

    print("\n=== 3. Топ частых слов (Униграммы) ===")
    # Используем CountVectorizer для подсчета слов, исключая английские и русские стоп-слова
    # (если тексты на русском, можно убрать 'english' или использовать nltk для русских стоп-слов)
    vectorizer = CountVectorizer(stop_words='english', max_features=20)
    
    for label in [0, 1]:
        print(f"\nТоп-10 слов для класса {label}:")
        texts = df[df[label_col] == label][text_col].dropna().astype(str)
        
        if len(texts) == 0:
            continue
            
        word_matrix = vectorizer.fit_transform(texts)
        word_frequencies = sum(word_matrix).toarray()[0]
        
        # Собираем в датафрейм для удобства
        freq_df = pd.DataFrame({
            'word': vectorizer.get_feature_names_out(),
            'count': word_frequencies
        }).sort_values(by='count', ascending=False).head(10)
        
        print(freq_df.to_string(index=False))

# --- Как использовать: ---
# 1. Загрузи свои данные
# my_data = pd.read_csv('my_dataset.csv')
# 2. Вызови функцию, указав названия колонок
# simple_text_eda(my_data, text_col='твой_текст', label_col='твой_таргет')
