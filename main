from sklearn.model_selection import cross_val_predict
from sklearn.metrics import precision_recall_curve
import matplotlib.pyplot as plt
import numpy as np

# Получаем вероятности предсказаний для всех данных с помощью кросс-валидации
print("Вычисляем вероятности (OOF Predictions)...")
y_proba_cv = cross_val_predict(pipeline_xgb, X, y, cv=cv_strategy, method='predict_proba', n_jobs=-1)[:, 1]

# Рассчитываем Precision и Recall для ВСЕХ возможных порогов от 0.0 до 1.0
precisions, recalls, thresholds = precision_recall_curve(y, y_proba_cv)

# Строим график компромисса
plt.figure(figsize=(10, 6))
plt.plot(thresholds, precisions[:-1], "b--", label="Precision (Точность)", linewidth=2)
plt.plot(thresholds, recalls[:-1], "g-", label="Recall (Полнота)", linewidth=2)

# Находим порог, при котором Recall будет около 0.90 (90%)
target_recall = 0.90
# Ищем индекс, где recall максимально близок к 90%
idx = np.argmin(np.abs(recalls - target_recall))
optimal_threshold = thresholds[idx]
expected_precision = precisions[idx]

plt.axvline(x=optimal_threshold, color='r', linestyle=':', label=f'Порог {optimal_threshold:.2f}')
plt.plot([optimal_threshold], [target_recall], 'ro')

plt.title('Баланс Precision и Recall в зависимости от порога')
plt.xlabel('Порог вероятности (Threshold)')
plt.ylabel('Значение метрики')
plt.legend(loc="lower left")
plt.grid(True)
plt.show()

print(f"Если мы снизим порог до {optimal_threshold:.2f}:")
print(f"-> Recall вырастет до ~{recalls[idx]:.3f} (Мы поймаем почти все атаки)")
print(f"-> Precision упадет до ~{expected_precision:.3f} (Доля ложных тревог)")
